---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  url?: string;
  noindex?: boolean;
}

const {
  title = "Sergej Wajciuk — Whitehat Lead Gen (PL/EU)",
  description = "Whitehat lead gen: Google Search, YouTube, TikTok, Push/Native. Pre-landingi i analityka.",
  url = "https://www.wajciukmedia.pl",
  noindex = false
} = Astro.props;

const canonical = new URL(Astro.url, Astro.site ?? url).toString();
---

<html lang="pl" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- Admitad verify (по требованию сети) -->
    <meta name="verify-admitad" content="912b1a6944" />

    
    <!-- Google Tag Manager — ТОЛЬКО GTM (НЕ gtag.js) -->
     <script is:inline>
       (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
       new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
     j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
       'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
       })(window,document,'script','dataLayer','GTM-TC968ZQZ');
    <!-- End Google Tag Manager -->
  </head>

  <body class="min-h-dvh bg-white text-gray-900 antialiased">
    <!-- Google Tag Manager (noscript) — строго сразу после <body> -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TC968ZQZ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <slot />

    <!-- Место для сторонних скриптов (если нужно). Загружать внизу, не в <head>. -->
    <!--
    <script is:inline>
      // пример загрузки внешнего скрипта
      (function(){var s=document.createElement('script');s.async=1;s.src='https://example.com/file.js';document.body.appendChild(s);}());
    </script>
    -->
  </body>
</html>
