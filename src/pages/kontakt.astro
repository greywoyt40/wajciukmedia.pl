---
import Base from "../layouts/Base.astro";
const email = "vaitsiuksv@gmail.com";
const whatsapp = "513 233 439";
---
<Base title="Kontakt — Sergej Wajciuk" description="Kontakt: Sergej Wajciuk, performance marketing i lead generation CPL/CPA.">
  <main class="legal-page">
    <header class="site-header"><div class="container header-inner"><a class="brand" href="/"><span class="sw-logo">SW</span><span><span class="brand-name">Sergej Wajciuk</span><span class="brand-sub">Performance Marketing</span></span></a><a class="header-cta" href={`mailto:${email}`}>Napisz wiadomość</a></div></header>
    <section class="legal-hero"><div class="container legal-card"><h1>Kontakt</h1><p>Napisz, jeżeli chcesz omówić ofertę, źródła ruchu, pre-landing lub setup trackingowy.</p><h2>E-mail</h2><p><a href={`mailto:${email}`}>{email}</a></p><h2>WhatsApp</h2><p><a href={`https://wa.me/48${whatsapp.replaceAll(' ', '')}`}>{whatsapp}</a></p></div></section>
  </main>
</Base>
